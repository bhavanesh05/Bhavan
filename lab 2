#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct node {
    struct node *prev;
    int ssn, phno;
    float sal;
    char name[20], dept[10], desg[20];
    struct node *next;
};

struct node *head = NULL, *tail = NULL;
int count = 0;

/* Create a node and return it */
struct node* createNode() {
    struct node *n = (struct node*)malloc(sizeof(struct node));

    printf("Enter SSN, Name, Dept, Designation, Salary, Phone: ");
    scanf("%d %s %s %s %f %d",
          &n->ssn, n->name, n->dept, n->desg, &n->sal, &n->phno);

    n->prev = NULL;
    n->next = NULL;

    return n;
}

/* Insert at end */
void insertEnd() {
    struct node *n = createNode();

    if (head == NULL) {
        head = tail = n;
    } else {
        tail->next = n;
        n->prev = tail;
        tail = n;
    }
    count++;
}



/* Insert at beginning */
void insertBeg() {
    struct node *n = createNode();

    if (head == NULL) {
        head = tail = n;
    } else {
        n->next = head;
        head->prev = n;
        head = n;
    }
    count++;
}

/* Delete at end */
void deleteEnd() {
    if (tail == NULL) {
        printf("List empty!\n");
        return;
    }

    struct node *temp = tail;
    printf("Deleted: %s\n", temp->name);

    if (head == tail) {  // Only one node
        head = tail = NULL;
    } else {
        tail = tail->prev;
        tail->next = NULL;
    }

    free(temp);
    count--;
}

/* Delete at beginning */
void deleteBeg() {
    if (head == NULL) {
        printf("List empty!\n");
        return;
    }

    struct node *temp = head;
    printf("Deleted: %s\n", temp->name);

    if (head == tail) {  // Only one node
        head = tail = NULL;
    } else {
        head = head->next;
        head->prev = NULL;
    }

    free(temp);
    count--;
}

/* Display */
void display() {
    if (head == NULL) {
        printf("List empty!\n");
        return;
    }

    struct node *p = head;
    printf("\nEmployee List:\n");

    while (p != NULL) {
        printf("%d %s %s %s %.2f %d\n",
               p->ssn, p->name, p->dept, p->desg, p->sal, p->phno);
        p = p->next;
    }
    printf("Total employees: %d\n", count);
}

int main() {
    int ch, n;

    while (1) {
        printf("\n--- MENU ---\n");
        printf("1. Create DLL of n employees\n");
        printf("2. Display\n");
        printf("3. Insert at End\n");
        printf("4. Delete from End\n");
        printf("5. Insert at Beginning\n");
        printf("6. Delete from Beginning\n");
        printf("7. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &ch);

        switch (ch) {
            case 1:
                printf("Enter number of employees: ");
                scanf("%d", &n);
                while (n--) insertEnd();
                break;
            case 2: display(); break;
            case 3: insertEnd(); break;
            case 4: deleteEnd(); break;
            case 5: insertBeg(); break;
            case 6: deleteBeg(); break;
            case 7: exit(0);
            default: printf("Invalid choice!\n");
        }
    }
    return 0;
}